# Kali companion — example configuration.
#
# Copy to `.env` and edit. All values can also be set as real environment
# variables (they take precedence).

# ── Server ───────────────────────────────────────────────
KALI_PORT=8900
# Bind to 0.0.0.0 for LAN / Tailnet access. Set to 127.0.0.1 for local-only.
KALI_HOST=0.0.0.0

# ── LLM (kali-mind) ───────────────────────────────────────
# Provider: "direct" (OpenAI-compatible) or "nanobot" (wraps nanobot WS).
KALI_LLM_PROVIDER=direct

# OpenAI-compatible endpoint. Works with:
#   - Ollama Cloud:    https://<your-ollama-cloud-host>/v1
#   - OpenRouter:      https://openrouter.ai/api/v1
#   - OpenAI:          https://api.openai.com/v1
#   - Local Ollama:    http://localhost:11434/v1
KALI_LLM_API_URL=https://api.openai.com/v1
KALI_LLM_API_KEY=sk-your-key-here
KALI_LLM_MODEL=gpt-4o-mini

# System prompt (the assistant's persona).
KALI_LLM_SYSTEM_PROMPT=You are Kali, a helpful desktop companion. Reply in the user's language.

# ── Nanobot (optional, only if KALI_LLM_PROVIDER=nanobot) ──
KALI_NANOBOT_WS_URL=ws://127.0.0.1:8765
KALI_NANOBOT_API_URL=http://127.0.0.1:8765
KALI_NANOBOT_TOKEN=

# ── TTS (kali-voice) ───────────────────────────────────────
# Provider: "inproc" (Piper in-process), "http" (external TTS service),
#          "qwen3" (Qwen3-TTS 0.6B CustomVoice), or "qwen3-voicedesign" (Qwen3-TTS 1.7B VoiceDesign).
KALI_TTS_PROVIDER=inproc
KALI_TTS_VOICE=glados-es
KALI_TTS_MODE=normal
KALI_TTS_MAX_LENGTH=2000
# Set to false to disable TTS entirely (no synthesis, no audio).
KALI_TTS_ENABLED=true

# Only used if KALI_TTS_PROVIDER=http. Must expose /v1/text-to-speech/<voice>.
KALI_TTS_HTTP_URL=http://localhost:3000

# ── Qwen3-TTS (only if KALI_TTS_PROVIDER=qwen3 or qwen3-voicedesign) ──
# Build the C++ binary first: scripts/build-qwen-cpp.sh cpu
#                              scripts/build-qwen-cpp.sh cuda   (for GPU)
# Download models first:        scripts/download-qwen-models.sh [model-id]
#
# Binaries are fixed (auto-resolved from kali_core/voice/qwen_cpp/):
#   CPU  -> build/tts-server
#   GPU  -> build-gpu/tts-server
# If the requested backend's binary is missing, Qwen falls back to CPU.
#
# Talker model for qwen3 (auto-detected):
#   KALI_QWEN_TALKER_MODEL=.../qwen-talker-0.6b-customvoice-Q4_K_M.gguf
#
# Talker model for qwen3-voicedesign (auto-detected):
#   KALI_QWEN_VOICEDESIGN_MODEL=.../qwen-talker-1.7b-voicedesign-Q4_K_M.gguf
#
# Codec/tokenizer model (shared, auto-detected):
# KALI_QWEN_CODEC_MODEL=
#
# Internal port for the C++ server (default: 8870):
# KALI_QWEN_PORT=8870
#
# Backend: CPU (default), CUDA0, CUDA1 (default device at startup;
# can be changed at runtime from the UI device selector):
# KALI_QWEN_BACKEND=CPU

# ── STT (kali-ear) ────────────────────────────────────────
# Provider: "vosk" (default, CPU-only) or "qwen3" (GPU-accelerated, requires torch)
KALI_STT_PROVIDER=vosk
KALI_STT_MODEL=vosk-model-small-es-0.42
KALI_STT_MODEL_EN=vosk-model-small-en-us-0.15
KALI_STT_LANGUAGE=es
KALI_STT_WAKE_WORD=false
KALI_STT_WAKE_WORD_THRESHOLD=0.3
KALI_STT_WAKE_WORD_COOLDOWN=2.0

# ── Qwen3-ASR (only if KALI_STT_PROVIDER=qwen3) ──────────
# Install deps first: pip install kali-core[qwen-stt]
# Models are auto-downloaded from HuggingFace on first load.
KALI_QWEN_ASR_MODEL=qwen3-asr-0.6b
KALI_QWEN_ASR_DEVICE=cpu
KALI_QWEN_ASR_STREAMING=true
KALI_QWEN_ASR_MODELS_DIR=~/.cache/huggingface/hub

# ── Web tools (kali-claws) ────────────────────────────────
KALI_SEARXNG_URL=http://127.0.0.1:8080

# ── Permissions (kali-collar) ──────────────────────────────
KALI_PROFILE=dev

# ── Kali Toys / Game AI ────────────────────────────────────
# Ruta de sesiones de juego (vacío = ~/.kali/game-sessions)
KALI_GAME_SESSION_PATH=

# Timeout global de razonamiento IA por jugada (ms).
KALI_GAME_AI_GLOBAL_TIMEOUT_MS=20000

# Conexión IA para juegos: "active" = usar conexión IA activa;
# otro valor = id de una conexión guardada para juegos exclusivos.
KALI_GAME_CONNECTION_ID=active

# Modelo dentro de la conexión de juegos (vacío = primer modelo disponible).
KALI_GAME_MODEL=

# Parámetros de generación de IA para juegos.
KALI_GAME_TEMPERATURE=0.7
KALI_GAME_MAX_TOKENS=256

# Timeouts por intento (ms), separados por coma.
KALI_GAME_RETRY_TIMEOUTS=12000,3000,2000

# Número máximo de reintentos.
KALI_GAME_MAX_RETRIES=2