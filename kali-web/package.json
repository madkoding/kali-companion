{
  "name": "kali-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kali frontend — the cat's face. React + Vite + TypeScript rendered inside the kali-home webview.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "framer-motion": "^11.3.0",
    "highlight.js": "^11.11.1",
    "i18next": "^23.11.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.439.0",
    "marked": "^12.0.2",
    "marked-highlight": "^2.2.4",
    "mermaid": "^11.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^7.18.0",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
