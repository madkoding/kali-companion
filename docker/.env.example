# =============================================================================
# Kali — Variables de entorno para Docker
# =============================================================================
# Copia este archivo a .env y edita los valores según tu configuración.
# Todas las variables son opcionales (tienen defaults razonables).
#
# Uso:
#   cp docker/.env.example .env
#   $EDITOR .env
#   docker compose up -d
# =============================================================================

# ── Core ────────────────────────────────────────────────────────────────────
# Puerto del servidor WebSocket + HTTP API de kali-core.
KALI_PORT=8900

# Puerto donde nginx sirve la interfaz web (kali-web).
KALI_WEB_PORT=8080

# Perfil de permisos: dev (todos permitidos), standard, restricted.
KALI_PROFILE=dev

# ── TTS Engine ───────────────────────────────────────────────────────────────
# Motor de síntesis de voz.
# Opciones:
#   inproc              Piper TTS en proceso (default, CPU, sin dependencias extra)
#   qwen3               Qwen3-TTS 0.6B CustomVoice (9 voces predefinidas)
#   qwen3-voicedesign   Qwen3-TTS 1.7B VoiceDesign (voz por descripción de texto)
#   http                Servicio TTS externo (compatible con lapis-tts)
KALI_TTS_PROVIDER=inproc

# Voz por defecto.
# Piper:     glados-es, robot-es
# Qwen3:     serena, vivian, ono_anna, sohee, aiden, dylan, eric, ryan, uncle_fu
# VoiceDesign: warm-female, deep-male, sad-female, energetic-male, whisper-female, elderly-male, cheerful-female, professional-male
KALI_TTS_VOICE=glados-es

# Modo de efectos de voz (solo Piper): normal, whisper, robotic, radio, deep, processed
KALI_TTS_MODE=normal

# Habilitar/deshabilitar TTS.
KALI_TTS_ENABLED=false

# URL del servicio TTS externo (solo si KALI_TTS_PROVIDER=http).
# Debe exponer /v1/text-to-speech/<voice>.
# KALI_TTS_HTTP_URL=http://localhost:3000

# ── STT Engine ───────────────────────────────────────────────────────────────
# Motor de reconocimiento de voz.
# Opciones:
#   vosk    Vosk STT offline (default)
#   qwen3   Qwen3 STT (placeholder, futuro)
KALI_STT_PROVIDER=vosk

# Modelo Vosk para español (se descarga desde la UI).
KALI_STT_MODEL=vosk-model-small-es-0.42

# Modelo Vosk para inglés (se descarga desde la UI).
KALI_STT_MODEL_EN=vosk-model-small-en-us-0.15

# Idioma por defecto: es, en.
KALI_STT_LANGUAGE=es

# Directorio de modelos Vosk (dentro del bind mount).
# KALI_STT_MODELS_DIR=/app/models/vosk

# Directorio de voces Piper (dentro del bind mount).
# KALI_VOICES_DIR=/app/models/piper-voices

# ── Qwen3-TTS (solo si KALI_TTS_PROVIDER=qwen3 o qwen3-voicedesign) ─────────
# Directorio donde se guardan los modelos Qwen3-TTS (.gguf).
# En Docker se monta desde ~/.local/share/kali/models en el host.
# En nativo, el default es ~/.local/share/kali/models.
# KALI_TTS_MODELS_DIR=/app/models

# Backend de inferencia: CPU (default), CUDA0, CUDA1.
# CUDA0 requiere Dockerfile.gpu + nvidia-container-toolkit.
# El binario se auto-resuelve (build/tts-server para CPU,
# build-gpu/tts-server para GPU); si falta el de GPU, cae a CPU.
KALI_QWEN_BACKEND=CPU

# Puerto interno del servidor C++ de Qwen3.
KALI_QWEN_PORT=8870

# ── LLM (Large Language Model) ──────────────────────────────────────────────
# Proveedor: direct (OpenAI-compatible) o nanobot.
KALI_LLM_PROVIDER=direct

# Endpoint OpenAI-compatible. Déjalo vacío para deshabilitar el LLM.
# Kali te pedirá configurarlo en Settings si no está definido.
#   Ollama local:  http://host.docker.internal:11434/v1
#   OpenAI:        https://api.openai.com/v1
#   OpenRouter:    https://openrouter.ai/api/v1
# KALI_LLM_API_URL=http://host.docker.internal:11434/v1

# API key (no necesaria para Ollama local).
# KALI_LLM_API_KEY=

# Nombre del modelo (debe coincidir con el modelo instalado en tu proveedor).
# KALI_LLM_MODEL=glm-5.1

# ── GPU (solo con Dockerfile.gpu) ───────────────────────────────────────────
# Dispositivos GPU visibles: all, 0, 1, etc.
NVIDIA_VISIBLE_DEVICES=all

# ── Paths (no modificar normalmente) ─────────────────────────────────────────
# Directorio de modelos descargados (montado como volumen kali-models).
# KALI_MODELS_DIR=/app/models

# Directorio de datos persistentes (montado como volumen kali-data).
# KALI_DATA_DIR=/app/data

# ── Kali Toys / Game AI ────────────────────────────────────────────────────
# Ruta de sesiones de juego.
# KALI_GAME_SESSION_PATH=/app/data/game-sessions

# Timeout global de razonamiento IA por jugada (ms).
KALI_GAME_AI_GLOBAL_TIMEOUT_MS=20000

# Conexión IA para juegos: "active" usa la activa;
# otro valor es el id de una conexión guardada.
KALI_GAME_CONNECTION_ID=active

# Modelo dentro de la conexión de juegos (vacío = primer modelo disponible).
# KALI_GAME_MODEL=

KALI_GAME_TEMPERATURE=0.7
KALI_GAME_MAX_TOKENS=256

# Timeouts por intento (ms), separados por coma.
KALI_GAME_RETRY_TIMEOUTS=12000,3000,2000

# Número máximo de reintentos.
KALI_GAME_MAX_RETRIES=2
